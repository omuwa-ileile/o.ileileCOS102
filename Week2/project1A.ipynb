   "source": [
    "START\n",
    "PRINT CALCULATE COST OF GOODS TO BE PURCHASED\n",
    "INPUT TOTAL NUMBER OF GOODS PICKED\n",
    "SET R TO NUMBER OF GOODS PICKED\n",
    "FOR i IN R\n",
    "INPUT CODE OF GOOD AND AMOUNT PICKED\n",
    "COMPUTE P = PRICE OF GOOD * AMOUNT PICKED\n",
    "ADD ALL VALUES OF P\n",
    "PRINT P TOTAL\n",
    "STOP"
   ]
